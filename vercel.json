{
    "functions": {
        "api/index.py": {
            "maxDuration": 60,
            "memory": 1024
        }
    },
    "rewrites": [
        {
            "source": "/_/backend/:path*",
            "destination": "/api/index.py"
        },
        {
            "source": "/:path*",
            "destination": "/frontend/:path*"
        }
    ]
}