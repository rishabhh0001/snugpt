{
    "functions": {
        "backend/app/main.py": {
            "maxDuration": 60,
            "memory": 1024
        }
    },
    "rewrites": [
        {
            "source": "/_/backend/:path*",
            "destination": "/backend/app/main.py"
        },
        {
            "source": "/(?!api/|_/backend/).*",
            "destination": "/frontend/$0"
        }
    ]
}